<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MusMux.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MusMux"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="MusMux">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <CommandBar HorizontalAlignment="Left" DefaultLabelPosition="Right" Grid.Row="0" Grid.Column="0">
            <AppBarButton Icon="Add" Label="Add Song" Click="AddFile_Click"/>
            <AppBarButton Icon="Folder" Label="Add Folder" Click="AddFolder_Click"/>
            <AppBarButton x:Name="RemoveSelected" Icon="Delete" Label="Remove" IsEnabled="False" Click="RemoveSelected_Click"/>
        </CommandBar>
        <ListView
            x:Name="SongListView"
            SelectionMode="Extended"
            ItemsSource="{x:Bind Songs}"
            SelectionChanged="SongListView_SelectionChanged"
            Grid.Row="1"
            Grid.Column="0">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:SongItem">
                    <StackPanel Spacing="12" Orientation="Horizontal" Margin="0,5,0,5">
                        <Button x:Name="SongPlay" Click="SongPlay_Click">
                            <FontIcon Glyph="&#xE102;"/> 
                        </Button>
                        <StackPanel>
                            <TextBlock Text="{x:Bind Title}" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind Artist}" Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid x:Name="BottomBar" Background="{ThemeResource LayerFillColorDefaultBrush}" Grid.Row="2" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="10*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <CommandBar HorizontalAlignment="Center" DefaultLabelPosition="Collapsed" Grid.Row="0" Grid.Column="1">
                <AppBarToggleButton x:Name="LoopToggle" Icon="RepeatAll" Label="Loop"/>
                <AppBarSeparator/>
                <AppBarButton Icon="Previous" Label="Previous" Click="MainPrev_Click"/>
                <AppBarButton x:Name="MainPlay" Icon="Play" Label="Play" Click="MainPlay_Click"/>
                <AppBarButton Icon="Next" Label="Next" Click="MainNext_Click"/>
                <AppBarSeparator/>
                <AppBarButton x:Name="VolumeButton" AllowFocusOnInteraction="True" Label="Volume">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE995;"/>
                    </AppBarButton.Icon>
                    <AppBarButton.Flyout>
                        <Flyout>
                            <Slider TickFrequency="10" TickPlacement="Outside" HorizontalAlignment="Center" Width="200" Maximum="100" Value="100" ValueChanged="VolumeSlider_ValueChanged"/>
                        </Flyout>
                    </AppBarButton.Flyout>
                </AppBarButton>
            </CommandBar>
            <Slider x:Name="SongSlider" HorizontalAlignment="Center" Width="360" Grid.Row="1" Grid.Column="1"/>
        </Grid>
    </Grid>
</Window>
